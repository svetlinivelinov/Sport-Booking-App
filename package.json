{
  "name": "sport-booking-app-v1",
  "version": "0.1.0",
  "private": true,
  "description": "Capstone monorepo: Next.js web/backend + Expo mobile + shared packages",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:mobile": "npm run start --workspace apps/mobile",
    "build:web": "npm run build --workspace apps/web",
    "build:mobile:web": "npm run export:web --workspace apps/mobile",
    "db:migrate": "npm run db:migrate --workspace apps/web",
    "db:seed:small": "npm run db:seed:small --workspace apps/web",
    "db:seed:large": "npm run db:seed:large --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web",
    "check:web-env": "powershell -ExecutionPolicy Bypass -File scripts/check-web-env.ps1",
    "test:smoke": "powershell -ExecutionPolicy Bypass -File scripts/test-current-app.ps1"
  },
  "engines": {
    "node": ">=20"
  }
}
