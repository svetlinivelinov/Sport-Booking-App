{
  "name": "sport-booking-app-v2",
  "version": "0.1.0",
  "private": true,
  "description": "Capstone monorepo bootstrap: Next.js web/backend + Expo mobile + shared packages",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:mobile": "npm run start --workspace apps/mobile",
    "build:web": "npm run build --workspace apps/web",
    "lint:web": "npm run lint --workspace apps/web"
  },
  "engines": {
    "node": ">=20"
  }
}